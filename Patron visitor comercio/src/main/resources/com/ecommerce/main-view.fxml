<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="viewController.MainController"
      stylesheets="@styles.css"
      styleClass="root-container"
      spacing="0">

    <!-- ToggleGroup declarado globalmente para poder referenciarlo desde los RadioButtons -->
    <fx:define>
        <ToggleGroup fx:id="grupoVisitador"/>
    </fx:define>

    <!-- ══════════════════════════  ENCABEZADO  ══════════════════════════ -->
    <HBox styleClass="header" alignment="CENTER_LEFT">
        <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
        <VBox spacing="2">
            <Label text="🛒  E-Commerce  ·  Patron Visitor" styleClass="header-title"/>
            <Label text="Aplica distintos comportamientos sin modificar los productos"
                   styleClass="header-sub"/>
        </VBox>
    </HBox>

    <!-- ═══════════════════════  CONTENIDO PRINCIPAL  ════════════════════ -->
    <HBox VBox.vgrow="ALWAYS" spacing="18" styleClass="content">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- ── Panel izquierdo: catalogo ────────────────────────────────── -->
        <VBox HBox.hgrow="ALWAYS" spacing="10">
            <Label text="📦  Catalogo de Productos" styleClass="section-title"/>

            <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS" styleClass="product-table">
                <columns>
                    <TableColumn fx:id="colTipo"    text="Tipo"        prefWidth="115" resizable="false"/>
                    <TableColumn fx:id="colNombre"  text="Nombre"      prefWidth="200"/>
                    <TableColumn fx:id="colPrecio"  text="Precio Base" prefWidth="120" resizable="false"/>
                    <TableColumn fx:id="colDetalle" text="Detalle"     prefWidth="220"/>
                </columns>
                <placeholder>
                    <Label text="Sin productos en el catalogo." style="-fx-text-fill: #999;"/>
                </placeholder>
            </TableView>

            <!-- Leyenda de tipos -->
            <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
                <Label text="📚 Libro" styleClass="legend-chip-libro"/>
                <Label text="💻 Electronico" styleClass="legend-chip-elec"/>
                <Label text="👕 Ropa" styleClass="legend-chip-ropa"/>
            </HBox>
        </VBox>

        <!-- ── Panel derecho: controles + resultados ───────────────────── -->
        <VBox spacing="16" prefWidth="400">

            <!-- Tarjeta: seleccion de visitador -->
            <VBox styleClass="card" spacing="14">
                <Label text="⚙  Seleccionar Operacion" styleClass="section-title"/>
                <Separator/>

                <RadioButton fx:id="rbImpuestos"
                             text="📊  Contabilidad — Calcular Impuestos"
                             toggleGroup="$grupoVisitador"
                             styleClass="radio-option"/>
                <Label text="    Libros 5% · Electronicos 19% · Ropa 12%"
                       styleClass="radio-hint"/>

                <RadioButton fx:id="rbEnvio"
                             text="🚚  Logistica — Costo de Envio"
                             toggleGroup="$grupoVisitador"
                             styleClass="radio-option"/>
                <Label text="    Segun peso en kg + cargo especial para electronicos"
                       styleClass="radio-hint"/>

                <RadioButton fx:id="rbDescuento"
                             text="🏷   Marketing — Aplicar Descuentos"
                             toggleGroup="$grupoVisitador"
                             styleClass="radio-option"/>
                <Label text="    Libros 15% · Electronicos 8% · Ropa 20%"
                       styleClass="radio-hint"/>

                <Button fx:id="btnAplicar"
                        text="▶  Aplicar Visitador"
                        onAction="#aplicarVisitador"
                        styleClass="btn-aplicar"
                        maxWidth="Infinity"/>
            </VBox>

            <!-- Tarjeta: resultados -->
            <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="10">
                <Label text="📋  Resultados" styleClass="section-title"/>
                <Separator/>
                <TextArea fx:id="areaResultados"
                          VBox.vgrow="ALWAYS"
                          editable="false"
                          wrapText="false"
                          styleClass="results-area"
                          promptText="Seleccione una operacion y presione Aplicar..."/>
                <Label fx:id="lblResumen" styleClass="summary-label" text=""/>
            </VBox>

        </VBox>
    </HBox>

    <!-- ════════════════════════  PIE DE PAGINA  ═════════════════════════ -->
    <HBox styleClass="footer" alignment="CENTER_RIGHT">
        <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
        <Label text="Patron Visitor  ·  SOLID  ·  POO  ·  JavaFX  —  Juan Manuel Vera v1.0"
               styleClass="footer-text"/>
    </HBox>

</VBox>
